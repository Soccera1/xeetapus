@item question @tab TEXT @tab NOT NULL @tab Poll question
@item duration_minutes @tab INTEGER @tab DEFAULT 1440 @tab Duration in minutes
@item created_at @tab DATETIME @tab DEFAULT CURRENT_TIMESTAMP @tab Creation time
@item ends_at @tab DATETIME @tab @tab Computed end time
