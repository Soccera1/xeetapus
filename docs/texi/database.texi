@headitem Column @tab Type @tab Constraints @tab Description
@item id @tab INTEGER @tab PRIMARY KEY AUTOINCREMENT @tab Unique option ID
@item poll_id @tab INTEGER @tab NOT NULL, FK(polls.id) @tab Parent poll
@item option_text @tab TEXT @tab NOT NULL @tab Option text
@item position @tab INTEGER @tab NOT NULL @tab Display order
@item vote_count @tab INTEGER @tab DEFAULT 0 @tab Number of votes
@end multitable
@end float

@float Table, tab:poll-votes
@caption{poll_votes}
@multitable @columnfractions 0.2 0.15 0.25 0.4
@headitem Column @tab Type @tab Constraints @tab Description
@item id @tab INTEGER @tab PRIMARY KEY AUTOINCREMENT @tab Unique vote ID
@item poll_id @tab INTEGER @tab NOT NULL, FK(polls.id) @tab Poll voted on
@item option_id @tab INTEGER @tab NOT NULL, FK(poll_options.id) @tab Chosen option
@item user_id @tab INTEGER @tab NOT NULL, FK(users.id) @tab Voter
