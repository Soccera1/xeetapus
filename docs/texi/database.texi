@item following_id @tab INTEGER @tab NOT NULL, FK(users.id) @tab User being followed
@item created_at @tab DATETIME @tab DEFAULT CURRENT_TIMESTAMP @tab Follow time
@end multitable
@end float

A unique constraint on @code{(follower_id, following_id)} prevents
