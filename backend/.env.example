# Xeetapus Backend Environment Configuration
# Copy this file to .env and fill in your actual values

# REQUIRED: JWT Secret for token signing
# Generate a strong random string (at least 32 characters)
# Example: openssl rand -base64 64
XEETAPUS_JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-chars

# CSRF Secret for CSRF token generation
# Generate a strong random string
XEETAPUS_CSRF_SECRET=your-csrf-secret-change-this-in-production

# Database path (optional, defaults to xeetapus.db)
XEETAPUS_DB_PATH=xeetapus.db

# Media storage path (optional, defaults to /var/www/xeetapus/media)
XEETAPUS_MEDIA_PATH=/var/www/xeetapus/media

# Server port (optional, defaults to 8080)
XEETAPUS_PORT=8080

# Environment: development, staging, or production
XEETAPUS_ENV=development

# CORS allowed origins (comma-separated)
# In production, specify your exact domains
XEETAPUS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Password hashing configuration
# Using Argon2id for modern password hashing
# Time cost (number of iterations) - higher is more secure but slower (default: 3)
# XEETAPUS_ARGON2_TIME_COST=3

# Memory cost in KB - higher is more secure but uses more memory (default: 65536 = 64MB)
# XEETAPUS_ARGON2_MEMORY_COST=65536

# Parallelism (number of threads) - should match your CPU cores (default: 4)
# XEETAPUS_ARGON2_PARALLELISM=4

# Maximum request size in bytes (optional, defaults to 10MB)
XEETAPUS_MAX_REQUEST_SIZE=1048576

# Rate limiting configuration
# Maximum requests per window (optional, defaults to 100)
XEETAPUS_RATE_LIMIT_REQUESTS=100

# Rate limit window in seconds (optional, defaults to 60)
XEETAPUS_RATE_LIMIT_WINDOW=60

# Authentication rate limiting configuration
# Maximum auth requests per window (optional, defaults to 5)
# Applies to login and register endpoints
XEETAPUS_AUTH_RATE_LIMIT_REQUESTS=5

# Auth rate limit window in seconds (optional, defaults to 300 = 5 minutes)
XEETAPUS_AUTH_RATE_LIMIT_WINDOW=300

# Server bind address (optional, defaults to 0.0.0.0)
# Set to 127.0.0.1 to only accept local connections
XEETAPUS_BIND_ADDR=0.0.0.0

# Monero Configuration
# Required for payment functionality
# Monero wallet address for receiving payments
XEETAPUS_MONERO_ADDRESS=YOUR_MONERO_WALLET_ADDRESS_HERE

# Monero daemon RPC URL (optional, defaults to http://localhost:18081)
# Used for fetching network fee estimates
XEETAPUS_MONEROD_URL=http://localhost:18081
