# Xeetapus Backend Environment Configuration
# Copy this file to .env and fill in your actual values

# REQUIRED: JWT Secret for token signing
# Generate a strong random string (at least 32 characters)
# Example: openssl rand -base64 64
XEETAPUS_JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-chars

# CSRF Secret for CSRF token generation
# Generate a strong random string
XEETAPUS_CSRF_SECRET=your-csrf-secret-change-this-in-production

# Database path (optional, defaults to xeetapus.db)
XEETAPUS_DB_PATH=xeetapus.db

# Server port (optional, defaults to 8080)
XEETAPUS_PORT=8080

# Environment: development, staging, or production
XEETAPUS_ENV=development

# CORS allowed origins (comma-separated)
# In production, specify your exact domains
XEETAPUS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Password hashing cost (optional, defaults to 12)
# Higher = more secure but slower
XEETAPUS_BCRYPT_COST=12

# Maximum request size in bytes (optional, defaults to 1MB)
XEETAPUS_MAX_REQUEST_SIZE=1048576

# Rate limiting configuration
# Maximum requests per window (optional, defaults to 100)
XEETAPUS_RATE_LIMIT_REQUESTS=100

# Rate limit window in seconds (optional, defaults to 60)
XEETAPUS_RATE_LIMIT_WINDOW=60
